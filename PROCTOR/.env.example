# Gemini API keys — fallback shared keys for users who haven't connected their own
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_API_KEY_2="YOUR_GEMINI_API_KEY_BACKUP"

# Google OAuth Client ID — enables "Sign in with Google" as a Gemini auth option
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create (or find) an OAuth 2.0 Web Client ID for the jaxx-micro-saas project
# 3. Add your hosting domain to "Authorized JavaScript origins"
#    e.g. https://jaxx-micro-saas.web.app and http://localhost:3002
# 4. Paste the Client ID below (it is public — not a secret)
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
